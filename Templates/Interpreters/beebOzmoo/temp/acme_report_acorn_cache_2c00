    35                              lsr
    36                              bcc +
    37                              ; relocate_target doesn't have the same double-page alignment as reloc_start,
    38                              ; so bump it up by one. It's harmless to modify relocate_target, because
    39                              ; it just means if we're restarted by re-running the executable it will
    40                              ; already have the right alignment.
    41                              inc relocate_target
    42                          +
    43                          }
