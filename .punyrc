# Puny BuildTools Bash resource file

# Wine related
export WINEDEBUG=-all
export WINEARCH=win32

# Puny BuildTools directories added at path
export PATH="/mnt/c/Source/Puny-BuildTools:$PATH"
export PATH="/mnt/c/Source/Puny-BuildTools/hfsutils:$PATH"
export PATH="/mnt/c/Source/Puny-BuildTools/z88dk/bin:$PATH"
export PATH="/mnt/c/Source/Puny-BuildTools/z88dk/lib:$PATH"
export PATH="/sbin:$PATH"
export ZCCCFG="/mnt/c/Source/Puny-BuildTools/z88dk/lib/config"
export PATH="$PATH:~/.local/bin"
